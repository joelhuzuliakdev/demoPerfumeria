---
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <div class="flex items-center justify-between h-20 lg:h-24">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
            <div class="w-8 h-8 relative">
            <svg id="logo-svg" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full text-white transition-colors duration-500">
                <ellipse cx="16" cy="22" rx="10" ry="8" stroke="currentColor" stroke-width="1.2"/>
                <rect x="13" y="10" width="6" height="12" rx="1" stroke="currentColor" stroke-width="1.2"/>
                <rect x="11" y="7" width="10" height="4" rx="2" stroke="currentColor" stroke-width="1.2"/>
                <line x1="16" y1="4" x2="16" y2="7" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            </div>
            <span id="logo-text" class="font-display text-xl tracking-[0.2em] uppercase text-white transition-colors duration-500">Aurum</span>
        </a>

        <!-- Nav Desktop -->
        <nav class="hidden lg:flex items-center gap-10">
            <a href="/" class="nav-link text-sm tracking-[0.15em] uppercase text-white/70 hover:text-white transition-colors duration-300 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-px after:bg-amber-500 after:transition-all after:duration-300 hover:after:w-full">Inicio</a>
            <a href="/productos" class="nav-link text-sm tracking-[0.15em] uppercase text-white/70 hover:text-white transition-colors duration-300 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-px after:bg-amber-500 after:transition-all after:duration-300 hover:after:w-full">Perfumes</a>
            <a href="/#nosotros" class="nav-link text-sm tracking-[0.15em] uppercase text-white/70 hover:text-white transition-colors duration-300 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-px after:bg-amber-500 after:transition-all after:duration-300 hover:after:w-full">Nosotros</a>
            <a href="/#contacto" class="nav-link text-sm tracking-[0.15em] uppercase text-white/70 hover:text-white transition-colors duration-300 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-px after:bg-amber-500 after:transition-all after:duration-300 hover:after:w-full">Contacto</a>
        </nav>

        <!-- CTA + Hamburger -->
        <div class="flex items-center gap-4">
            <a href="/productos" class="hidden lg:inline-flex items-center gap-2 px-7 py-3 bg-white/10 border border-white/30 text-white text-xs tracking-[0.2em] uppercase hover:bg-white hover:text-stone-900 transition-all duration-300 group" id="cta-btn">
            <span>Comprar ahora</span>
            <svg class="w-3 h-3 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>

            <!-- Hamburger -->
            <button id="menu-toggle" class="lg:hidden flex flex-col gap-[5px] p-2 group" aria-label="Menú">
            <span class="hamburger-line w-6 h-px bg-white transition-all duration-300 group-[.open]:rotate-45 group-[.open]:translate-y-[6px]"></span>
            <span class="hamburger-line w-4 h-px bg-white transition-all duration-300 group-[.open]:opacity-0"></span>
            <span class="hamburger-line w-6 h-px bg-white transition-all duration-300 group-[.open]:-rotate-45 group-[.open]:-translate-y-[6px]"></span>
            </button>
        </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden max-h-0 overflow-hidden transition-all duration-500 bg-white/98 backdrop-blur-md border-t border-stone-100">
        <nav class="flex flex-col px-6 py-6 gap-5">
        <a href="/" class="mobile-nav text-sm tracking-[0.15em] uppercase text-stone-700 py-2 border-b border-stone-100">Inicio</a>
        <a href="/productos" class="mobile-nav text-sm tracking-[0.15em] uppercase text-stone-700 py-2 border-b border-stone-100">Perfumes</a>
        <a href="/#nosotros" class="mobile-nav text-sm tracking-[0.15em] uppercase text-stone-700 py-2 border-b border-stone-100">Nosotros</a>
        <a href="/#contacto" class="mobile-nav text-sm tracking-[0.15em] uppercase text-stone-700 py-2 border-b border-stone-100">Contacto</a>
        <a href="/productos" class="mt-2 inline-flex justify-center items-center px-8 py-3 bg-stone-900 text-white text-xs tracking-[0.2em] uppercase">Comprar ahora</a>
        </nav>
    </div>
</header>

<script>
    const header = document.getElementById('header');
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const logoText = document.getElementById('logo-text');
    const logoSvg = document.getElementById('logo-svg') as SVGElement | null;
    const navLinks = document.querySelectorAll<HTMLElement>('.nav-link');
    const ctaBtn = document.getElementById('cta-btn');
    const hamburgerLines = document.querySelectorAll<HTMLElement>('.hamburger-line');

    // En páginas que no son la home, el header siempre está en modo "scrolled" (oscuro sobre blanco)
    const isHome = window.location.pathname === '/' || window.location.pathname === '';

    function setScrolled(scrolled: boolean) {
        if (scrolled) {
        header?.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-stone-100');
        if (logoText) { logoText.classList.remove('text-white'); logoText.classList.add('text-stone-900'); }
        if (logoSvg)  { logoSvg.classList.remove('text-white'); logoSvg.classList.add('text-amber-800'); }
        navLinks.forEach(l => { l.classList.remove('text-white/70', 'hover:text-white'); l.classList.add('text-stone-600', 'hover:text-stone-900'); });
        if (ctaBtn) { ctaBtn.classList.remove('bg-white/10', 'border-white/30', 'text-white', 'hover:bg-white', 'hover:text-stone-900'); ctaBtn.classList.add('bg-stone-900', 'text-white', 'hover:bg-amber-900', 'border-transparent'); }
        hamburgerLines.forEach(l => { l.classList.remove('bg-white'); l.classList.add('bg-stone-900'); });
        } else {
        header?.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-stone-100');
        if (logoText) { logoText.classList.add('text-white'); logoText.classList.remove('text-stone-900'); }
        if (logoSvg)  { logoSvg.classList.add('text-white'); logoSvg.classList.remove('text-amber-800'); }
        navLinks.forEach(l => { l.classList.add('text-white/70', 'hover:text-white'); l.classList.remove('text-stone-600', 'hover:text-stone-900'); });
        if (ctaBtn) { ctaBtn.classList.add('bg-white/10', 'border-white/30', 'text-white', 'hover:bg-white', 'hover:text-stone-900'); ctaBtn.classList.remove('bg-stone-900', 'hover:bg-amber-900', 'border-transparent'); }
        hamburgerLines.forEach(l => { l.classList.add('bg-white'); l.classList.remove('bg-stone-900'); });
        }
    }

    // En la home: depende del scroll. En otras páginas: siempre modo scrolled
    setScrolled(!isHome || window.scrollY > 50);

    window.addEventListener('scroll', () => {
        setScrolled(!isHome || window.scrollY > 50);
    }, { passive: true });

    // Mobile menu
    toggle?.addEventListener('click', () => {
        toggle.classList.toggle('open');
        if (menu) {
        if (menu.style.maxHeight === '0px' || menu.style.maxHeight === '') {
            menu.style.maxHeight = menu.scrollHeight + 'px';
        } else {
            menu.style.maxHeight = '0px';
        }
        }
    });

    // Cerrar al hacer click en link del mobile menu
    document.querySelectorAll('.mobile-nav').forEach(link => {
        link.addEventListener('click', () => {
        toggle?.classList.remove('open');
        if (menu) menu.style.maxHeight = '0px';
        });
    });
</script>