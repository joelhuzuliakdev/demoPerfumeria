---
import '../styles/global.css'
interface Props {
	title?: string;
	description?: string;
}

const { 
	title = 'Aurum Fragrancias — Perfumes de Autor',
	description = 'Descubrí nuestra colección de perfumes de autor. Fragancias únicas y exclusivas para quienes buscan lo extraordinario.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-stone-50 text-stone-900 antialiased overflow-x-hidden">
		<slot />
	</body>
</html>