---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { productos } from '../data/productos.js';

// Solo mostramos los primeros 6 en la home
const products = productos.slice(0, 6);

const benefits = [
	{
		icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
		title: '100% Originales',
		desc: 'Todas nuestras fragancias son auténticas y certificadas. Garantizamos la calidad en cada frasco.'
	},
	{
		icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
		title: 'Envíos a todo el país',
		desc: 'Despachamos a cualquier punto de Argentina. Packaging premium y seguro garantizado.'
	},
	{
		icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
		title: 'Fragancias exclusivas',
		desc: 'Colecciones únicas creadas por perfumistas de renombre internacional. Arte en cada gota.'
	},
	{
		icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
		title: 'Compra segura',
		desc: 'Transacciones protegidas y datos encriptados. Tu seguridad es nuestra prioridad.'
	},
];	
---

<Layout>
	<Header />

	<main>
		<!-- ═══════════════════════════════════════════
			HERO SECTION
		══════════════════════════════════════════════ -->
		<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden bg-stone-950">

		<!-- Background texture -->
		<div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\")"></div>

		<!-- Gold gradient blobs -->
		<div class="absolute top-1/4 right-0 w-[600px] h-[600px] rounded-full opacity-10 blur-3xl" style="background: radial-gradient(circle, #92400e 0%, transparent 70%)"></div>
		<div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] rounded-full opacity-[0.08] blur-3xl" style="background: radial-gradient(circle, #b45309 0%, transparent 70%)"></div>

		<div class="relative mx-auto max-w-7xl px-6 lg:px-10 w-full pt-36 pb-28 lg:pt-0 lg:pb-0">
			<div class="grid lg:grid-cols-2 items-center gap-16 lg:gap-8 min-h-screen lg:pt-24">

			<!-- Text Content -->
			<div class="hero-content order-2 lg:order-1">
				<div class="flex items-center gap-3 mb-8 hero-fade" style="animation-delay: 0.1s">
				<div class="h-px w-12 bg-amber-700"></div>
				<span class="text-amber-600 text-xs tracking-[0.3em] uppercase font-body">Colección 2025</span>
				</div>

				<h1 class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-8xl text-white leading-[1.05] mb-8 hero-fade" style="animation-delay: 0.2s">
				Descubrí tu<br/>
				<em class="text-amber-600/90 not-italic">fragancia</em><br/>
				perfecta
				</h1>

				<p class="text-stone-400 text-lg font-body font-light leading-relaxed max-w-md mb-12 hero-fade" style="animation-delay: 0.35s">
				Fragancias de autor que trascienden lo ordinario. Cada perfume cuenta una historia, cada nota despierta una emoción.
				</p>

				<div class="flex flex-wrap items-center gap-5 hero-fade" style="animation-delay: 0.5s">
				<a href="#perfumes" class="group inline-flex items-center gap-3 px-8 py-4 bg-amber-800 hover:bg-amber-700 text-white text-sm tracking-[0.15em] uppercase transition-all duration-300">
					Explorar perfumes
					<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
				</a>
				<a href="#nosotros" class="inline-flex items-center gap-2 text-stone-400 hover:text-stone-200 text-sm tracking-[0.1em] uppercase transition-colors duration-300">
					<span>Nuestra historia</span>
				</a>
				</div>

				<!-- Stats -->
				<div class="flex items-center gap-10 mt-16 pt-10 pb-16 lg:pb-24 border-t border-stone-800/60 hero-fade" style="animation-delay: 0.65s">
				<div>
					<p class="font-display text-3xl text-white">+200</p>
					<p class="text-stone-500 text-xs tracking-[0.15em] uppercase mt-1">Fragancias</p>
				</div>
				<div class="w-px h-10 bg-stone-800"></div>
				<div>
					<p class="font-display text-3xl text-white">8 años</p>
					<p class="text-stone-500 text-xs tracking-[0.15em] uppercase mt-1">De experiencia</p>
				</div>
				<div class="w-px h-10 bg-stone-800"></div>
				<div>
					<p class="font-display text-3xl text-white">+5k</p>
					<p class="text-stone-500 text-xs tracking-[0.15em] uppercase mt-1">Clientes</p>
				</div>
				</div>
			</div>

			<!-- Hero Visual -->
			<div class="order-1 lg:order-2 flex justify-center lg:justify-end hero-fade" style="animation-delay: 0.3s">
				<div class="relative">
				<!-- Decorative circle -->
				<div class="absolute inset-[-40px] rounded-full border border-stone-700/30 animate-spin-slow"></div>
				<div class="absolute inset-[-80px] rounded-full border border-stone-800/20 animate-spin-reverse"></div>

				<!-- Bottle SVG -->
				<div class="relative w-72 h-96 lg:w-80 lg:h-[440px] flex items-center justify-center">
					<svg viewBox="0 0 200 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full drop-shadow-2xl">
					<!-- Cap -->
					<rect x="72" y="20" width="56" height="30" rx="4" fill="#92400e"/>
					<rect x="76" y="24" width="48" height="22" rx="3" fill="#b45309"/>
					<!-- Neck -->
					<rect x="85" y="48" width="30" height="28" fill="#7c6b4a"/>
					<rect x="88" y="51" width="24" height="22" fill="#a0926e"/>
					<!-- Shoulder connector -->
					<path d="M75 76 Q75 100 50 110 L50 270 Q50 285 100 285 Q150 285 150 270 L150 110 Q125 100 125 76 Z" fill="#1a1208"/>
					<!-- Glass body gradient simulation -->
					<path d="M78 78 Q78 102 55 112 L55 268 Q55 280 100 280 Q145 280 145 268 L145 112 Q122 102 122 78 Z" fill="url(#bottleGrad)"/>
					<!-- Reflection -->
					<path d="M65 115 Q62 150 62 200 L62 260" stroke="rgba(255,255,255,0.08)" stroke-width="8" stroke-linecap="round"/>
					<path d="M75 108 Q72 135 72 175 L72 250" stroke="rgba(255,255,255,0.05)" stroke-width="4" stroke-linecap="round"/>
					<!-- Label area -->
					<rect x="65" y="145" width="70" height="90" rx="2" fill="rgba(255,255,255,0.04)" stroke="rgba(255,200,80,0.15)" stroke-width="0.5"/>
					<!-- Label text sim -->
					<text x="100" y="178" font-size="11" fill="rgba(200,160,60,0.8)" text-anchor="middle" font-family="serif" font-style="italic">Noctis</text>
					<text x="100" y="193" font-size="6" fill="rgba(180,140,50,0.5)" text-anchor="middle" font-family="sans-serif" letter-spacing="3">AURUM</text>
					<line x1="75" y1="202" x2="125" y2="202" stroke="rgba(180,140,50,0.2)" stroke-width="0.5"/>
					<text x="100" y="215" font-size="5.5" fill="rgba(180,140,50,0.4)" text-anchor="middle" letter-spacing="2">EAU DE PARFUM</text>
					<!-- Bottom base -->
					<ellipse cx="100" cy="277" rx="50" ry="8" fill="rgba(0,0,0,0.4)"/>

					<defs>
						<linearGradient id="bottleGrad" x1="55" y1="78" x2="145" y2="78" gradientUnits="userSpaceOnUse">
						<stop offset="0%" stop-color="#2d1e0e"/>
						<stop offset="30%" stop-color="#4a3218"/>
						<stop offset="60%" stop-color="#2d1e0e"/>
						<stop offset="100%" stop-color="#1a1208"/>
						</linearGradient>
					</defs>
					</svg>

					<!-- Floating particles -->
					<div class="absolute top-8 right-4 w-1.5 h-1.5 rounded-full bg-amber-600/60 animate-float" style="animation-delay: 0s"></div>
					<div class="absolute top-20 left-2 w-1 h-1 rounded-full bg-amber-500/40 animate-float" style="animation-delay: 0.7s"></div>
					<div class="absolute bottom-20 right-2 w-2 h-2 rounded-full bg-amber-700/30 animate-float" style="animation-delay: 1.4s"></div>
				</div>
				</div>
			</div>

			</div>
		</div>

		<!-- Scroll indicator -->
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce-slow">
			<span class="text-stone-600 text-[10px] tracking-[0.25em] uppercase">Scroll</span>
			<div class="w-px h-10 bg-gradient-to-b from-stone-600 to-transparent"></div>
		</div>
		</section>


		<!-- ═══════════════════════════════════════════
			PRODUCTOS DESTACADOS
		══════════════════════════════════════════════ -->
		<section id="perfumes" class="py-28 lg:py-36 bg-white">
		<div class="mx-auto max-w-7xl px-6 lg:px-10">

			<!-- Section header -->
			<div class="mb-16 lg:mb-20 reveal">
			<div class="flex items-center gap-3 mb-5">
				<div class="h-px w-10 bg-amber-700"></div>
				<span class="text-amber-700 text-xs tracking-[0.3em] uppercase">Colección</span>
			</div>
			<div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6">
				<h2 class="font-display text-4xl sm:text-5xl lg:text-6xl text-stone-900 leading-tight max-w-md">
				Perfumes<br/><em class="text-stone-500 not-italic">destacados</em>
				</h2>
				<p class="text-stone-500 font-body max-w-sm leading-relaxed">
				Cada fragancia es una obra artesanal. Elige la que mejor refleje tu esencia.
				</p>
			</div>
			</div>

			<!-- Product Grid -->
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
			{products.map((product, i) => (
				<article
				class={`product-card group relative overflow-hidden cursor-pointer ${product.bg} reveal`}
				style={`animation-delay: ${i * 0.1}s`}
				>
				<!-- Accent overlay -->
				<div class={`absolute inset-0 ${product.accent} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>

				<div class="relative p-8 lg:p-10 flex flex-col h-full min-h-[380px]">

					<!-- Badge -->
					<div class="flex items-center justify-between mb-8">
					<span class={`text-xs tracking-[0.2em] uppercase ${product.textColor} opacity-40`}>{product.intensity}</span>
					<span class={`text-xs tracking-[0.15em] uppercase ${product.textColor} opacity-30`}>{product.subtitle}</span>
					</div>

					<!-- Bottle visual -->
					<div class="flex-1 flex items-center justify-center mb-8">
					<div class="relative transition-transform duration-700 group-hover:-translate-y-3">
						<svg viewBox="0 0 100 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-20 h-28 drop-shadow-xl">
						<rect x="36" y="8" width="28" height="16" rx="3" fill={product.capColor} opacity="0.9"/>
						<rect x="42" y="24" width="16" height="14" fill={product.capColor} opacity="0.6"/>
						<path d="M34 38 Q34 50 22 55 L22 140 Q22 148 50 148 Q78 148 78 140 L78 55 Q66 50 66 38 Z" fill={product.bottleColor} opacity="0.9"/>
						<path d="M37 40 Q37 52 26 57 L26 138 Q26 144 50 144 Q74 144 74 138 L74 57 Q63 52 63 40 Z" fill={product.bottleColor} opacity="0.5"/>
						<path d="M32 58 Q30 80 30 105 L30 135" stroke="rgba(255,255,255,0.08)" stroke-width="5" stroke-linecap="round"/>
						<rect x="34" y="75" width="32" height="45" rx="1" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.08)" stroke-width="0.5"/>
						<text x="50" y="98" font-size="6" fill="rgba(255,255,255,0.4)" text-anchor="middle" font-family="serif" font-style="italic">{product.name}</text>
						<text x="50" y="109" font-size="3.5" fill="rgba(255,255,255,0.2)" text-anchor="middle" letter-spacing="2">AURUM</text>
						<ellipse cx="50" cy="145" rx="28" ry="4" fill="rgba(0,0,0,0.2)"/>
						</svg>
					</div>
					</div>

					<!-- Product info -->
					<div>
					<h3 class={`font-display text-2xl lg:text-3xl mb-1 ${product.textColor}`}>{product.name}</h3>
					<p class={`text-xs tracking-[0.15em] uppercase mb-4 ${product.textColor} opacity-40`}>{product.notes}</p>

					<div class="flex items-center justify-between">
						<span class={`font-display text-xl ${product.textColor}`}>{product.price}</span>
						<button class={`group/btn flex items-center gap-2 px-5 py-2.5 border text-xs tracking-[0.15em] uppercase transition-all duration-300 ${
						product.bg.includes('stone-900') || product.bg.includes('zinc-950') || product.bg.includes('stone-700')
							? 'border-stone-600 text-stone-300 hover:bg-white hover:text-stone-900 hover:border-white'
							: 'border-stone-400 text-stone-700 hover:bg-stone-900 hover:text-white hover:border-stone-900'
						}`}>
						<span>Comprar</span>
						<svg class="w-3 h-3 transition-transform duration-300 group-hover/btn:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
						</button>
					</div>
					</div>

				</div>
				</article>
			))}
			</div>

			<!-- CTA ver todos -->
			<div class="text-center mt-14 reveal">
			<a href="/productos" class="group inline-flex items-center gap-3 px-10 py-4 border border-stone-300 text-stone-700 text-sm tracking-[0.2em] uppercase hover:bg-stone-900 hover:text-white hover:border-stone-900 transition-all duration-300">
				<span>Ver todos los perfumes</span>
				<svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
			</a>
			</div>

		</div>
		</section>
		
		<section class="py-24 lg:py-32 bg-stone-950 relative overflow-hidden">
		<!-- Decorative line -->
		<div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-900/40 to-transparent"></div>

		<div class="mx-auto max-w-7xl px-6 lg:px-10">

			<div class="text-center mb-16 reveal">
			<div class="flex items-center justify-center gap-3 mb-5">
				<div class="h-px w-10 bg-amber-700"></div>
				<span class="text-amber-700 text-xs tracking-[0.3em] uppercase">Por qué elegirnos</span>
				<div class="h-px w-10 bg-amber-700"></div>
			</div>
			<h2 class="font-display text-4xl sm:text-5xl text-white">
				La experiencia <em class="text-amber-600/80 not-italic">Aurum</em>
			</h2>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
			{benefits.map((b, i) => (
				<div class={`benefit-card group p-8 border border-stone-800 hover:border-amber-900/60 bg-stone-900/40 hover:bg-stone-900/70 transition-all duration-500 reveal`} style={`animation-delay: ${i * 0.1}s`}>
				<div class="w-12 h-12 flex items-center justify-center bg-amber-900/20 text-amber-600 group-hover:bg-amber-900/40 transition-colors duration-300 mb-6" set:html={b.icon}></div>
				<h3 class="text-white font-body font-medium tracking-wide mb-3">{b.title}</h3>
				<p class="text-stone-500 text-sm font-body leading-relaxed">{b.desc}</p>
				</div>
			))}
			</div>

		</div>

		<div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-900/40 to-transparent"></div>
		</section>


		<!-- ═══════════════════════════════════════════
			SOBRE LA MARCA
		══════════════════════════════════════════════ -->
		<section id="nosotros" class="py-28 lg:py-40 bg-stone-50">
		<div class="mx-auto max-w-7xl px-6 lg:px-10">
			<div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

			<!-- Visual side -->
			<div class="reveal order-2 lg:order-1">
				<div class="relative">
				<!-- Main visual block -->
				<div class="aspect-[4/5] bg-stone-900 relative overflow-hidden">
					<!-- Abstract perfume visualization -->
					<div class="absolute inset-0 flex items-center justify-center">
					<svg viewBox="0 0 400 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full opacity-80">
						<!-- Background gradient -->
						<rect width="400" height="500" fill="url(#bgGrad2)"/>
						<!-- Abstract liquid shapes -->
						<ellipse cx="200" cy="350" rx="120" ry="30" fill="rgba(146,64,14,0.15)"/>
						<ellipse cx="200" cy="345" rx="100" ry="22" fill="rgba(146,64,14,0.2)"/>
						<!-- Tall elegant bottle -->
						<rect x="162" y="80" width="76" height="40" rx="5" fill="#92400e"/>
						<rect x="168" y="86" width="64" height="28" rx="3" fill="#b45309"/>
						<!-- Neck -->
						<rect x="180" y="118" width="40" height="36" fill="#7c6b4a"/>
						<!-- Body -->
						<path d="M155 154 Q155 175 130 185 L130 340 Q130 360 200 360 Q270 360 270 340 L270 185 Q245 175 245 154 Z" fill="url(#bottleMainAbout)"/>
						<!-- Highlight -->
						<path d="M148 188 Q145 230 145 280 L145 335" stroke="rgba(255,255,255,0.06)" stroke-width="14" stroke-linecap="round"/>
						<!-- Label -->
						<rect x="155" y="220" width="90" height="100" rx="2" fill="rgba(255,255,255,0.03)" stroke="rgba(200,160,60,0.1)" stroke-width="0.8"/>
						<text x="200" y="260" font-size="16" fill="rgba(200,160,60,0.6)" text-anchor="middle" font-family="serif" font-style="italic">Aurum</text>
						<text x="200" y="278" font-size="7" fill="rgba(200,160,60,0.3)" text-anchor="middle" letter-spacing="4">FRAGRANCIAS</text>
						<!-- Floating notes -->
						<circle cx="120" cy="160" r="3" fill="rgba(180,140,50,0.4)"/>
						<circle cx="310" cy="200" r="2" fill="rgba(180,140,50,0.3)"/>
						<circle cx="90" cy="250" r="4" fill="rgba(180,140,50,0.2)"/>
						<circle cx="320" cy="280" r="2.5" fill="rgba(180,140,50,0.25)"/>
						<!-- Wavy lines for fragrance -->
						<path d="M200 80 Q210 60 200 40 Q190 20 200 0" stroke="rgba(180,140,50,0.15)" stroke-width="1.5" stroke-dasharray="4 4"/>

						<defs>
						<linearGradient id="bgGrad2" x1="0" y1="0" x2="400" y2="500" gradientUnits="userSpaceOnUse">
							<stop offset="0%" stop-color="#1c1917"/>
							<stop offset="100%" stop-color="#0c0a09"/>
						</linearGradient>
						<linearGradient id="bottleMainAbout" x1="130" y1="154" x2="270" y2="154" gradientUnits="userSpaceOnUse">
							<stop offset="0%" stop-color="#2d1e0e"/>
							<stop offset="40%" stop-color="#6b4c24"/>
							<stop offset="70%" stop-color="#3d2810"/>
							<stop offset="100%" stop-color="#1a1208"/>
						</linearGradient>
						</defs>
					</svg>
					</div>
				</div>

				<!-- Floating accent card -->
				<div class="absolute -bottom-6 -right-6 lg:-right-10 bg-amber-900 p-6 lg:p-8 w-44 lg:w-52">
					<p class="font-display text-4xl lg:text-5xl text-white">8</p>
					<p class="text-amber-200 text-xs tracking-[0.15em] uppercase mt-1">Años creando fragancias únicas</p>
				</div>
				</div>
			</div>

			<!-- Text side -->
			<div class="reveal order-1 lg:order-2" style="animation-delay: 0.2s">
				<div class="flex items-center gap-3 mb-6">
				<div class="h-px w-10 bg-amber-700"></div>
				<span class="text-amber-700 text-xs tracking-[0.3em] uppercase">Nuestra historia</span>
				</div>

				<h2 class="font-display text-4xl sm:text-5xl lg:text-6xl text-stone-900 leading-tight mb-8">
				Arte en cada<br/>
				<em class="text-stone-500 not-italic">gota</em>
				</h2>

				<div class="space-y-5 text-stone-600 font-body leading-relaxed">
				<p>
