---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { productos, intensidades } from '../data/productos.js';
---

<Layout title="Todos los Perfumes — Aurum Fragrancias" description="Explorá nuestra colección completa de perfumes de autor.">
    <Header />

    <main class="bg-stone-50 min-h-screen">

        <!-- Page Header -->
        <section class="bg-stone-950 pt-40 pb-20 relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;)"></div>
        <div class="absolute top-0 right-0 w-[500px] h-[400px] opacity-10 blur-3xl" style="background: radial-gradient(circle, #92400e 0%, transparent 70%)"></div>

        <div class="relative mx-auto max-w-7xl px-6 lg:px-10">
            <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl text-white leading-tight">
            Toda la<br/><em class="text-amber-600/90 not-italic">colección</em>
            </h1>
            <p class="text-stone-400 mt-5 font-body max-w-md leading-relaxed">
            {productos.length} fragancias únicas. Desde frescas y suaves hasta profundas e intensas. Encontrá la tuya.
            </p>
        </div>
        </section>

        <!-- Filter Bar -->
        <div class="sticky top-20 lg:top-24 z-40 bg-white/95 backdrop-blur-md border-b border-stone-200 shadow-sm">
        <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <div class="flex items-center gap-2 py-4 overflow-x-auto scrollbar-hide">
            {intensidades.map(intensidad => (
                <button
                class="filter-btn whitespace-nowrap px-4 py-2 text-xs tracking-[0.15em] uppercase border border-stone-200 text-black hover:border-amber-700 hover:text-amber-700 transition-all duration-200"
                data-filter={intensidad}
                >
                {intensidad}
                </button>
            ))}
            </div>
        </div>
        </div>

        <!-- Products Grid -->
        <div class="mx-auto max-w-7xl px-6 lg:px-10 py-16">

        <!-- Count indicator -->
        <div class="flex items-center justify-between mb-10">
            <p class="text-stone-500 text-sm font-body">
            Mostrando <span id="product-count" class="text-stone-900 font-medium">{productos.length}</span> fragancias
            </p>
            <a href="/" class="flex items-center gap-2 text-stone-400 hover:text-stone-700 text-xs tracking-[0.15em] uppercase transition-colors duration-300">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            <span>Volver al inicio</span>
            </a>
        </div>

        <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
            {productos.map((product) => (
            <article
                class={`product-card group relative overflow-hidden cursor-pointer ${product.bg}`}
                data-intensity={product.intensity}
            >
                <!-- Accent overlay -->
                <div class={`absolute inset-0 ${product.accent} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>

                <div class="relative p-6 lg:p-8 flex flex-col h-full min-h-[340px]">

                <!-- Badge -->
                <div class="flex items-center justify-between mb-6">
                    <span class={`text-xs tracking-[0.2em] uppercase ${product.textColor} opacity-40`}>{product.intensity}</span>
                    <span class={`text-xs tracking-[0.12em] uppercase ${product.textColor} opacity-25`}>{product.ml}</span>
                </div>

                <!-- Bottle -->
                <div class="flex-1 flex items-center justify-center mb-6">
                    <div class="relative transition-transform duration-700 group-hover:-translate-y-3">
                    <svg viewBox="0 0 100 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-16 h-24 drop-shadow-xl">
                        <rect x="36" y="8" width="28" height="16" rx="3" fill={product.capColor} opacity="0.9"/>
                        <rect x="42" y="24" width="16" height="14" fill={product.capColor} opacity="0.6"/>
                        <path d="M34 38 Q34 50 22 55 L22 140 Q22 148 50 148 Q78 148 78 140 L78 55 Q66 50 66 38 Z" fill={product.bottleColor} opacity="0.9"/>
                        <path d="M37 40 Q37 52 26 57 L26 138 Q26 144 50 144 Q74 144 74 138 L74 57 Q63 52 63 40 Z" fill={product.bottleColor} opacity="0.5"/>
                        <path d="M32 58 Q30 80 30 105 L30 135" stroke="rgba(255,255,255,0.08)" stroke-width="5" stroke-linecap="round"/>
                        <rect x="34" y="75" width="32" height="45" rx="1" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.08)" stroke-width="0.5"/>
                        <text x="50" y="98" font-size="6" fill="rgba(255,255,255,0.4)" text-anchor="middle" font-family="serif" font-style="italic">{product.name}</text>
                        <text x="50" y="109" font-size="3.5" fill="rgba(255,255,255,0.2)" text-anchor="middle" letter-spacing="2">AURUM</text>
                        <ellipse cx="50" cy="145" rx="28" ry="4" fill="rgba(0,0,0,0.2)"/>
                    </svg>
                    </div>
                </div>

                <!-- Info -->
                <div>
                    <h2 class={`font-display text-xl lg:text-2xl mb-0.5 ${product.textColor}`}>{product.name}</h2>
                    <p class={`text-xs tracking-[0.12em] uppercase mb-3 ${product.textColor} opacity-35`}>{product.notes}</p>
                    <p class={`text-xs font-body leading-relaxed mb-4 ${product.textColor} opacity-50 line-clamp-2`}>{product.description}</p>

                    <div class="flex items-center justify-between">
                    <span class={`font-display text-lg ${product.textColor}`}>{product.price}</span>
                    <button class={`group/btn flex items-center gap-1.5 px-4 py-2 border text-xs tracking-[0.12em] uppercase transition-all duration-300 ${
                        product.bg.includes('stone-9') || product.bg.includes('zinc-9') || product.bg.includes('stone-7') || product.bg.includes('red-9') || product.bg.includes('emerald-9') || product.bg.includes('yellow-9')
                        ? 'border-stone-600 text-stone-300 hover:bg-white hover:text-stone-900 hover:border-white'
                        : 'border-stone-300 text-stone-600 hover:bg-stone-900 hover:text-white hover:border-stone-900'
                    }`}>
                        <span>Comprar</span>
                        <svg class="w-3 h-3 transition-transform duration-300 group-hover/btn:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </button>
                    </div>
                </div>

                </div>
            </article>
            ))}
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden text-center py-24">
            <p class="font-display text-3xl text-stone-400 mb-3">Sin resultados</p>
            <p class="text-stone-400 text-sm font-body">No hay fragancias con esa intensidad.</p>
            <button class="filter-reset mt-6 text-amber-700 text-xs tracking-[0.2em] uppercase hover:text-amber-900 transition-colors duration-300">Mostrar todas</button>
        </div>

        </div>

        <!-- WhatsApp CTA -->
        <section class="bg-stone-950 py-16">
        <div class="mx-auto max-w-7xl px-6 lg:px-10 flex flex-col sm:flex-row items-center justify-between gap-6">
            <div>
            <p class="font-display text-2xl text-white mb-1">¿No encontrás lo que buscás?</p>
            <p class="text-stone-400 text-sm font-body">Consultanos por WhatsApp y te asesoramos personalmente.</p>
            </div>
            <a href="https://wa.me/5491100000000" target="_blank" class="shrink-0 group inline-flex items-center gap-3 px-8 py-4 bg-amber-800 hover:bg-amber-700 text-white text-sm tracking-[0.15em] uppercase transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>Consultar ahora</span>
            </a>
        </div>
        </section>

    </main>

    <Footer />
</Layout>

<style>
    .font-display { font-family: 'Cormorant Garamond', Georgia, serif; }
    .font-body    { font-family: 'Jost', system-ui, sans-serif; }

    :global(body) {
        font-family: 'Jost', system-ui, sans-serif;
        font-weight: 300;
    }
    :global(html) { scroll-behavior: smooth; }

    .product-card {
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px -12px rgba(0,0,0,0.2);
    }
    .product-card.hidden-card {
        display: none;
    }

    .filter-btn.active {
        background-color: #1c1917;
        color: white;
        border-color: #1c1917;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Hide scrollbar on filter bar */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
    const filterBtns = document.querySelectorAll<HTMLElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.product-card');
    const countEl = document.getElementById('product-count');
    const emptyState = document.getElementById('empty-state');
    const resetBtns = document.querySelectorAll('.filter-reset');

    function applyFilter(filter: string) {
        let visible = 0;

        // Update button states
        filterBtns.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.filter === filter);
        });

        // Show/hide cards
        cards.forEach(card => {
        const match = filter === 'Todos' || card.dataset.intensity === filter;
        card.classList.toggle('hidden-card', !match);
        if (match) visible++;
        });

        // Update count
        if (countEl) countEl.textContent = String(visible);

        // Empty state
        if (emptyState) emptyState.classList.toggle('hidden', visible > 0);
    }

    // Init: activate "Todos"
    applyFilter('Todos');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
        applyFilter(btn.dataset.filter ?? 'Todos');
        });
    });

    resetBtns.forEach(btn => {
        btn.addEventListener('click', () => applyFilter('Todos'));
    });
</script>